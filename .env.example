# Database (PostgreSQL). If password contains @ or #, URL-encode as %40 or %23.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# AWS S3 (document storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=aircraft-poc-documents

# Ledger: use "postgres" to use same DB for audit log, or "file" for local file
LEDGER_BACKEND=postgres
# LEDGER_FILE_PATH=./data/ledger.jsonl  # if LEDGER_BACKEND=file

# Anthropic Claude (optional: leave empty to use MockTechnicalAgent for demo/testing)
ANTHROPIC_API_KEY=

# App
LOG_LEVEL=INFO
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050
