# Database: postgres | snowflake
DATABASE_BACKEND=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
# Snowflake (when DATABASE_BACKEND=snowflake)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=AVIATION_AI
SNOWFLAKE_SCHEMA=POC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=

# AWS S3 (document storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=aircraft-poc-documents

# Ledger: postgres | file | qldb
LEDGER_BACKEND=postgres
# LEDGER_FILE_PATH=./data/ledger.jsonl  # when LEDGER_BACKEND=file
# QLDB_LEDGER_NAME=aviation-audit  # when LEDGER_BACKEND=qldb (create table audit_ledger in AWS)

# Anthropic Claude (required)
ANTHROPIC_API_KEY=

# App
LOG_LEVEL=INFO
JSON_LOGS=false
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050
USE_AGENT_REGISTRY=false
