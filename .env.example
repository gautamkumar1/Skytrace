# Database: postgres | snowflake
DATABASE_BACKEND=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
# Snowflake (when DATABASE_BACKEND=snowflake)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=AVIATION_AI
SNOWFLAKE_SCHEMA=POC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=
# If you get 404 on login, add your region (e.g. us-east-1, eu-west-1):
# SNOWFLAKE_REGION=us-east-1
# If your user has MFA/TOTP, set current 6-digit code (or create a user without MFA for automation):
# SNOWFLAKE_TOTP_PASSCODE=123456
# Key-pair auth (no password/MFA): path to RSA private key (.p8 or .pem), and optional passphrase if encrypted:
# SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# AWS S3 (document storage). Set FORCE_LOCAL_STORAGE=true to use ./data/storage instead (e.g. when bucket doesn't exist)
FORCE_LOCAL_STORAGE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=aircraft-poc-documents

# Ledger: postgres | file | qldb
LEDGER_BACKEND=postgres
# LEDGER_FILE_PATH=./data/ledger.jsonl  # when LEDGER_BACKEND=file
# QLDB_LEDGER_NAME=aviation-audit  # when LEDGER_BACKEND=qldb (create table audit_ledger in AWS)

# Agent: openai | anthropic
AGENT_PROVIDER=openai
# OpenAI (required when AGENT_PROVIDER=openai)
OPENAI_API_KEY=
# Anthropic Claude (required when AGENT_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# App
LOG_LEVEL=INFO
JSON_LOGS=false
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050
USE_AGENT_REGISTRY=false
